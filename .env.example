# Скопируйте в .env и заполните (файл .env в git не коммитится)
GOOGLE_API_KEY=

# Проверка ключа и ответа модели:  python3 check_gemini_key.py
# Либо при запущенном rag_server:  curl -s http://127.0.0.1:8787/api/verify-key

# Опционально:
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_CALL_TIMEOUT=240
# GEMINI_MAX_OUTPUT_TOKENS=16384
# GEMINI_JSON_MODE=1
# GEMINI_ASSIST_RETRY=1
# RAG_ROUTING=1
# RAG_AUDIENCE_FILTER=1
# RAG_MAX_CHUNKS=6
# RAG_EXCERPT_CHARS=700
# GEMINI_PROMPT_MAX_CHARS=28000
