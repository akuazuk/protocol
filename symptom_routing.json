    },
    {
      "id": "sinus_query_not_spine_deform_pdf",
      "when_query": ["гаймор", "синусит", "пазух", "придаточн", "этмоид"],
      "unless_query": ["позвоночник", "сколиоз", "остеохондроз", "деформац", "ортопед"],
      "path_contains": ["деформац", "позвоноч", "сколиоз"],
