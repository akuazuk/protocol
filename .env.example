# Скопируйте в .env и заполните (файл .env в git не коммитится)
GOOGLE_API_KEY=

# Render.com (в панели сервиса → Environment, не в git):
# PYTHON_VERSION=3.11.8
# GOOGLE_API_KEY=...

# Опционально:
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Опционально для экспериментов: gemini-3-flash-preview (качество JSON/калибровка могут отличаться)
# GEMINI_CALL_TIMEOUT=240
# GEMINI_MAX_OUTPUT_TOKENS=16384
# GEMINI_JSON_MODE=1
# GEMINI_ASSIST_RETRY=1
# RAG_ROUTING=1
# RAG_AUDIENCE_FILTER=1
# RAG_MAX_CHUNKS=6
# RAG_EXCERPT_CHARS=700
# GEMINI_PROMPT_MAX_CHARS=28000
# GEMINI_SPECIALTY_CLASSIFY=0   # 1 — доп. вызов LLM: к каким рубрикам относится запрос (усиливает отбор)
# GEMINI_EXTRACT_FULL_MATCH=1   # развёрнутая выдержка: при 100% — сразу в /api/assist; при 80–99% — кнопка → POST /api/protocol-detail
# RAG_EXTRACT_MAX_CHARS=16000
# RAG_CATEGORY_BOOST_FACTOR=1.45
# RAG_CHUNKS_SOURCE=          # пусто — авто: corpus_chunks_parts/*.jsonl если есть, иначе chunks.json
# RAG_CHUNKS_SOURCE=json      # принудительно старый build_chunks.py (chunks.json)
# RAG_CHUNKS_JSONL=           # один файл JSONL (напр. output/chunks/chunks.jsonl)
# RAG_CHUNKS_JSONL_GLOB=      # свой glob относительно корня проекта
# RAG_USER_CATEGORY_BOOST=2.05   # множитель релевантности, если чанк в выбранной пользователем рубрике
# RAG_USER_CATEGORY_PENALTY=0.32 # ослабление, если рубрика чанка не среди выбранных
# RAG_USER_CATEGORY_UNCERTAIN=0.78 # при отсутствии рубрики у чанка
# RAG_EXTRACT_FULL_MATCH_MAX_CHARS=32000  # объём текста протокола при извлечении при 100% соответствии
# RAG_DETAIL_EXTRACT_MIN_SCORE=0.8  # порог (0–1) для развёрнутой выдержки; по умолчанию 0.8 = 80%
# Развёрнутая выдержка по протоколу (extract_clinical_detail)
# RAG_EXTRACT_FULL_MATCH_MAX_CHARS=32000
# RAG_EXTRACT_PROMPT_MAX_CHARS=    # пусто = как GEMINI_PROMPT_MAX_CHARS; иначе лимит промпта для извлечения
# RAG_EXTRACT_ITEM_MAX_CHARS=420    # обрезка одного пункта в списках investigations/medications/treatment_methods
# RAG_EXTRACT_GAP_RETRY=1
# RAG_EXTRACT_NON_PROTOCOL_FALLBACK=1
# RAG_EXTRACT_NON_PROTOCOL_MONITORING_ONLY=0  # 1 — общеклинический fallback только для кратности наблюдения
# RAG_DETAIL_WARN_RAG_SUPPORT=0.22  # ниже — предупреждение «слабый отбор» при переданном client_rag_support
# RAG_SPELLFIX_ON_EMPTY=1          # при пустом лексическом отборе — исправить опечатки моделью и повторить поиск
# RAG_GEMINI_QUERY_REFINE=1        # перед поиском — уточнить жалобу через Gemini (терминология МКБ/протоколы)
# RAG_QUERY_REFINE_TIMEOUT=45      # таймаут вызова (сек.) для уточнения жалобы
# GEMINI_SPELLFIX_TIMEOUT=45       # таймаут короткого вызова исправления (с)
# RAG_MEMORY_SAVER=          # 1 — экономия RAM (без дубля embedding_ready_text); по умолчанию выкл. — полный lex
# RAG_LEXICAL_MAX_CHARS=0    # если >0 — обрезать lex_text для поиска (ещё ниже RAM)
#
# Гибридный отбор: лексика + BM25 + Gemini Embedding 2 (переранжирование пула)
# RAG_LEX_BM25_ALPHA=0.55          # 1.0 — только лексика без BM25
# RAG_BM25_K1=1.5
# RAG_BM25_B=0.75
# RAG_EMBED_POOL_MERGE=1           # объединить топ по score и топ по BM25 перед эмбеддингом
# RAG_GEMINI_EMBED_RERANK=1
# GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2-preview
# RAG_EMBED_POOL=44            # по умолчанию в коде; больше — шире пул перед embed-rerank (дороже по API)
# RAG_EMBED_POOL=48
# RAG_HYBRID_ALPHA=0.35
#
# Согласование оценки модели с отбором фрагментов (rag_support)
# RAG_LLM_CONF_BLEND_W=0.62
# RAG_MIN_RAG_SUPPORT_CAP=0.74
# RAG_MIN_RAG_SUPPORT_FOR_HIGH_CONF=0.2
# RAG_DETAIL_MIN_RAG_SUPPORT=0.12  # порог rag_support для авторазвёрнутой выдержки
# RAG_ICD_META_BOOST=1.35          # если в protocol_meta заданы icd_codes и пересечение с запросом
#
# RAG_CHUNK_VOTE_RERETRIEVE=0      # 1 — второй retrieve с рубрикой по голосу чанков (дольше)
# RAG_CONFIDENCE_SECOND_PASS=0     # 1 — короткий второй вызов Gemini для калибровки %
# RAG_CONFIDENCE_SECOND_BLEND=0.55
#
# МКБ-10: JSON из Excel (см. data/icd_reference/README.md и scripts/export_icd_ru_from_xlsx.py)
# ICD_RU_XLSX=data/icd_reference/mkb10_minzdrav_rb.xlsx
# ICD_RU_JSON=data/icd_reference/icd10_ru_mkb10su.json
#
# Подбор кодов через Gemini только из лексического пула; эмбеддинги по кодам отключены по умолчанию.
# RAG_ICD_GEMINI_SELECT=1
# RAG_ICD_GEMINI_MIN_TOP_SCORE=0.8   # верхний score отбора протокола (0–1) после эмбеддинг-переранжирования
# RAG_ICD_GEMINI_REQUIRE_EMBED_RANK=1  # 0 — разрешить подбор без гибридного score (не рекомендуется)
# RAG_ICD_LEX_TOP=12
# RAG_ICD_EMBED_POOL=32
# RAG_ICD_EMBED_K=0                  # 0 — не добавлять кандидатов МКБ через эмбеддинг (только лексикон)
# RAG_ICD_EMBED_RANK=1               # при RAG_ICD_EMBED_K>0 — ранжировать пул эмбеддингом
# GEMINI_EMBED_CALL_TIMEOUT=45
# GEMINI_TEMPLATE_MAX_TOKENS=8192
# GEMINI_TEMPLATE_DRAFT_MAX_CHARS=100000
# GEMINI_TEMPLATE_PROMPT_MAX_CHARS=28000
