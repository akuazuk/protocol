# Скопируйте в .env и заполните (файл .env в git не коммитится)
GOOGLE_API_KEY=

# Render.com (в панели сервиса → Environment, не в git):
# PYTHON_VERSION=3.11.8
# GOOGLE_API_KEY=...

# Опционально:
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Опционально для экспериментов: gemini-3-flash-preview (качество JSON/калибровка могут отличаться)
# GEMINI_CALL_TIMEOUT=240
# GEMINI_MAX_OUTPUT_TOKENS=16384
# GEMINI_JSON_MODE=1
# GEMINI_ASSIST_RETRY=1
# RAG_ROUTING=1
# RAG_AUDIENCE_FILTER=1
# RAG_MAX_CHUNKS=6
# RAG_EXCERPT_CHARS=700
# GEMINI_PROMPT_MAX_CHARS=28000
# GEMINI_SPECIALTY_CLASSIFY=0   # 1 — доп. вызов LLM: к каким рубрикам относится запрос (усиливает отбор)
# GEMINI_EXTRACT_FULL_MATCH=1   # развёрнутая выдержка: при 100% — сразу в /api/assist; при 80–99% — кнопка → POST /api/protocol-detail
# RAG_EXTRACT_MAX_CHARS=16000
# RAG_CATEGORY_BOOST_FACTOR=1.45
# RAG_CHUNKS_SOURCE=          # пусто — авто: corpus_chunks_parts/*.jsonl если есть, иначе chunks.json
# RAG_CHUNKS_SOURCE=json      # принудительно старый build_chunks.py (chunks.json)
# RAG_CHUNKS_JSONL=           # один файл JSONL (напр. output/chunks/chunks.jsonl)
# RAG_CHUNKS_JSONL_GLOB=      # свой glob относительно корня проекта
# RAG_USER_CATEGORY_BOOST=2.05   # множитель релевантности, если чанк в выбранной пользователем рубрике
# RAG_USER_CATEGORY_PENALTY=0.32 # ослабление, если рубрика чанка не среди выбранных
# RAG_USER_CATEGORY_UNCERTAIN=0.78 # при отсутствии рубрики у чанка
# RAG_EXTRACT_FULL_MATCH_MAX_CHARS=32000  # объём текста протокола при извлечении при 100% соответствии
# RAG_DETAIL_EXTRACT_MIN_SCORE=0.8  # порог (0–1) для развёрнутой выдержки; по умолчанию 0.8 = 80%
# RAG_SPELLFIX_ON_EMPTY=1          # при пустом лексическом отборе — исправить опечатки моделью и повторить поиск
# GEMINI_SPELLFIX_TIMEOUT=45       # таймаут короткого вызова исправления (с)
# RAG_MEMORY_SAVER=          # 1 — экономия RAM (без дубля embedding_ready_text); по умолчанию выкл. — полный lex
# RAG_LEXICAL_MAX_CHARS=0    # если >0 — обрезать lex_text для поиска (ещё ниже RAM)
#
# Гибридный отбор: лексика + Gemini Embedding 2 (переранжирование пула кандидатов)
# RAG_GEMINI_EMBED_RERANK=1
# GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2-preview
# RAG_EMBED_POOL=40
# RAG_HYBRID_ALPHA=0.35
# GEMINI_EMBED_CALL_TIMEOUT=45
# GEMINI_TEMPLATE_MAX_TOKENS=8192
# GEMINI_TEMPLATE_DRAFT_MAX_CHARS=100000
# GEMINI_TEMPLATE_PROMPT_MAX_CHARS=28000
